root = true

[*]
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

[*.{sh,bash}]
indent_style = space
indent_size = 4

# Extensionless bash wrappers and git hooks
[{z,commit-msg,pre-push}]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab

[*.ps1]
indent_style = space
indent_size = 4
end_of_line = crlf

[*.py]
indent_style = space
indent_size = 4

[*.yml]
indent_style = space
indent_size = 2

[*.toml]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false
