# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
dist/
build/
*.egg-info/
nanvix-zutil-templates-*.tar.gz

# Example build artifacts
examples/**/build/
examples/**/*.o
examples/**/*.elf

# Virtual environments
.venv/
venv/
.nanvix/venv/

# Nanvix build artifacts (downloaded sysroot, buildroot, cache, config)
**/.nanvix/sysroot/
**/.nanvix/buildroot/
**/.nanvix/cache/
**/.nanvix/env.json
logs/

# pytest
.pytest_cache/
.coverage
htmlcov/

# Type checker caches
.basedpyright/
.pyright/
!pyrightconfig.json

# Files synced into consumer .nanvix/ dirs by `nanvix-zutil setup` /
# release tooling. The canonical copies live in
# src/nanvix_zutil/configs/ and templates/; the in-tree copies under
# .nanvix/ are regenerated on every run and would otherwise show up as
# spurious diffs (especially in examples/, which are exercised by the
# test suite).
**/.nanvix/.gitignore
**/.nanvix/.yamllint.yml
**/.nanvix/black.toml
**/.nanvix/pyrightconfig.json

# Editor
/.vscode
/.vscode/
/.zed/
.idea/
*.swp
*~

# Downstream test artifacts (generated per-user)
scripts/downstream/downstream.json
scripts/downstream/consumer-repos.json

# OS
.DS_Store
Thumbs.db
logs
